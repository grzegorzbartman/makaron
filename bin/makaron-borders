#!/bin/bash
# Toggle or set window borders (JankyBorders).
# Persists BORDERS_ENABLED in makaron.conf and delegates layout to apply_desktop_state.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/makaron-ui-helpers"

_toggle_or_set() {
    case "${1:-}" in
        on)  echo "true" ;;
        off) echo "false" ;;
        *)
            [[ "$(_get_gaps_zero_enabled)" == "true" ]] && echo "true" && return
            [[ "$(_get_borders_enabled)" == "true" ]] && echo "false" || echo "true"
            ;;
    esac
}

new_value="$(_toggle_or_set "${1:-}")"
set_makaron_conf_value "BORDERS_ENABLED" "$new_value"
[[ "$new_value" == "true" ]] && set_makaron_conf_value "GAPS_ZERO_ENABLED" "false"
[[ "$new_value" == "true" ]] && echo "Borders enabled" || echo "Borders disabled"

# Single source of truth: re-derive layout from ui-mode + makaron.conf.
# Warns when ui-mode=stop (config saved, nothing applied to running system).
MAKARON_APPLY_VERBOSE=1 apply_desktop_state
