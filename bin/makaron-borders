#!/bin/bash
# Toggle or set window borders (JankyBorders).
# Persists BORDERS_ENABLED in makaron.conf and delegates layout to apply_desktop_state.

MAKARON_CONF="$HOME/.config/makaron/makaron.conf"
source "$MAKARON_CONF" 2>/dev/null

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/makaron-ui-helpers"

_set_borders_enabled() {
    local value="$1"
    if grep -q "^BORDERS_ENABLED=" "$MAKARON_CONF" 2>/dev/null; then
        sed -i '' "s/^BORDERS_ENABLED=.*/BORDERS_ENABLED=$value/" "$MAKARON_CONF"
    else
        echo "BORDERS_ENABLED=$value" >> "$MAKARON_CONF"
    fi
}

case "${1:-}" in
    on)  _set_borders_enabled true;  echo "Borders enabled" ;;
    off) _set_borders_enabled false; echo "Borders disabled" ;;
    *)
        if [[ "${BORDERS_ENABLED:-true}" == "true" ]]; then
            _set_borders_enabled false; echo "Borders disabled"
        else
            _set_borders_enabled true;  echo "Borders enabled"
        fi
        ;;
esac

# Single source of truth: re-derive layout from ui-mode + makaron.conf.
# Warns when ui-mode=stop (config saved, nothing applied to running system).
MAKARON_APPLY_VERBOSE=1 apply_desktop_state
