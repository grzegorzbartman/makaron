#!/bin/bash
# Toggle or set window borders (JankyBorders)

MAKARON_CONF="$HOME/.config/makaron/makaron.conf"
source "$MAKARON_CONF" 2>/dev/null

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/makaron-ui-helpers"

_set_borders_enabled() {
    local value="$1"
    if grep -q "^BORDERS_ENABLED=" "$MAKARON_CONF" 2>/dev/null; then
        sed -i '' "s/^BORDERS_ENABLED=.*/BORDERS_ENABLED=$value/" "$MAKARON_CONF"
    else
        echo "BORDERS_ENABLED=$value" >> "$MAKARON_CONF"
    fi
}

case "${1:-}" in
    on)
        _set_borders_enabled true
        BORDERS_ENABLED=true
        start_borders
        echo "Borders enabled"
        ;;
    off)
        _set_borders_enabled false
        stop_borders
        echo "Borders disabled"
        ;;
    *)
        # Toggle
        if [[ "${BORDERS_ENABLED:-true}" == "true" ]]; then
            _set_borders_enabled false
            stop_borders
            echo "Borders disabled"
        else
            _set_borders_enabled true
            BORDERS_ENABLED=true
            start_borders
            echo "Borders enabled"
        fi
        ;;
esac
