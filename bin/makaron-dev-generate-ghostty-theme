#!/usr/bin/env python3
"""Generate a Ghostty theme file from makaron theme colors."""

import colorsys
import sys
import os

def makaron_to_rgb(color):
    """Convert 0xAARRGGBB to (r, g, b) floats 0-1."""
    hex_str = color.replace("0x", "").replace("0X", "")
    r = int(hex_str[2:4], 16) / 255.0
    g = int(hex_str[4:6], 16) / 255.0
    b = int(hex_str[6:8], 16) / 255.0
    return (r, g, b)

def rgb_to_hex(r, g, b):
    return "#{:02x}{:02x}{:02x}".format(int(r * 255), int(g * 255), int(b * 255))

def clamp(v):
    return max(0.0, min(1.0, v))

def adjust_lightness(rgb, factor):
    h, l, s = colorsys.rgb_to_hls(*rgb)
    l = clamp(l * factor)
    return colorsys.hls_to_rgb(h, l, s)

def set_lightness(rgb, target_l):
    h, l, s = colorsys.rgb_to_hls(*rgb)
    return colorsys.hls_to_rgb(h, clamp(target_l), s)

def rotate_hue(rgb, degrees):
    h, l, s = colorsys.rgb_to_hls(*rgb)
    h = (h + degrees / 360.0) % 1.0
    return colorsys.hls_to_rgb(h, l, s)

def generate_ansi_from_accent(accent_rgb, is_dark):
    """Generate 16 ANSI colors from an accent color by hue rotation."""
    h, l, s = colorsys.rgb_to_hls(*accent_rgb)

    # Target hues for ANSI colors (in degrees)
    # 0=black, 1=red, 2=green, 3=yellow, 4=blue, 5=magenta, 6=cyan, 7=white
    hue_targets = {
        1: 0,      # red
        2: 120,    # green
        3: 60,     # yellow
        4: 240,    # blue
        5: 300,    # magenta
        6: 180,    # cyan
    }

    if is_dark:
        normal_l = clamp(l * 0.85) if l > 0.3 else max(l, 0.35)
        bright_l = clamp(normal_l * 1.25)
        sat = max(s, 0.5)
    else:
        normal_l = clamp(l * 1.1) if l < 0.7 else min(l, 0.45)
        bright_l = clamp(normal_l * 0.85)
        sat = max(s, 0.5)

    colors = {}
    for idx, hue_deg in hue_targets.items():
        target_h = hue_deg / 360.0
        colors[idx] = colorsys.hls_to_rgb(target_h, normal_l, sat)
        colors[idx + 8] = colorsys.hls_to_rgb(target_h, bright_l, sat)

    return colors

def parse_shell_var(lines, var_name):
    for line in lines:
        line = line.strip()
        if line.startswith(f"export {var_name}=") or line.startswith(f"{var_name}="):
            val = line.split("=", 1)[1].strip().strip('"').strip("'")
            return val
    return None

def main():
    if len(sys.argv) < 2:
        print("Usage: makaron-dev-generate-ghostty-theme <theme-name>", file=sys.stderr)
        print("Generates a Ghostty palette from theme's sketchybar/borders colors.", file=sys.stderr)
        sys.exit(1)

    theme_name = sys.argv[1]
    makaron_path = os.environ.get("MAKARON_PATH", os.path.expanduser("~/.local/share/makaron"))

    # Also check dev repo
    script_dir = os.path.dirname(os.path.abspath(__file__))
    repo_path = os.path.dirname(script_dir)

    theme_dir = os.path.join(repo_path, "themes", theme_name)
    if not os.path.isdir(theme_dir):
        theme_dir = os.path.join(makaron_path, "themes", theme_name)
    if not os.path.isdir(theme_dir):
        print(f"Theme '{theme_name}' not found", file=sys.stderr)
        sys.exit(1)

    # Read color files
    sketchybar_file = os.path.join(theme_dir, "sketchybar.colors")
    borders_file = os.path.join(theme_dir, "borders.colors")
    mode_file = os.path.join(theme_dir, "mode")

    with open(sketchybar_file) as f:
        sk_lines = f.readlines()
    with open(borders_file) as f:
        br_lines = f.readlines()

    is_dark = True
    if os.path.exists(mode_file):
        with open(mode_file) as f:
            is_dark = f.read().strip() == "dark"

    all_lines = sk_lines + br_lines

    # Extract colors
    bar_color = parse_shell_var(all_lines, "BAR_COLOR")
    icon_color = parse_shell_var(all_lines, "ICON_COLOR")
    space_bg = parse_shell_var(all_lines, "SPACE_BACKGROUND_COLOR")
    space_border = parse_shell_var(all_lines, "SPACE_BORDER_COLOR")
    focused_border = parse_shell_var(all_lines, "SPACE_FOCUSED_BORDER_COLOR")
    active_border = parse_shell_var(all_lines, "ACTIVE_BORDER_COLOR")
    inactive_border = parse_shell_var(all_lines, "INACTIVE_BORDER_COLOR")

    bg_rgb = makaron_to_rgb(bar_color)
    fg_rgb = makaron_to_rgb(icon_color)
    # Pick the most saturated color as accent
    candidates = [c for c in [focused_border, active_border] if c]
    if candidates:
        def saturation(c):
            _, _, s = colorsys.rgb_to_hls(*makaron_to_rgb(c))
            return s
        accent_rgb = makaron_to_rgb(max(candidates, key=saturation))
    else:
        accent_rgb = fg_rgb
    space_bg_rgb = makaron_to_rgb(space_bg)
    inactive_rgb = makaron_to_rgb(inactive_border)

    # Generate palette
    ansi = generate_ansi_from_accent(accent_rgb, is_dark)

    # Black/white from theme colors
    if is_dark:
        ansi[0] = adjust_lightness(bg_rgb, 0.7)       # black: darker than bg
        ansi[7] = fg_rgb                                # white: fg color
        ansi[8] = inactive_rgb                          # bright black: dim
        ansi[15] = adjust_lightness(fg_rgb, 1.2)       # bright white: brighter fg
    else:
        ansi[0] = adjust_lightness(bg_rgb, 0.6)
        ansi[7] = adjust_lightness(fg_rgb, 1.1)
        ansi[8] = inactive_rgb
        ansi[15] = adjust_lightness(fg_rgb, 0.8)

    # Output
    print(f"background = {rgb_to_hex(*bg_rgb)}")
    print(f"foreground = {rgb_to_hex(*fg_rgb)}")
    print(f"cursor-color = {rgb_to_hex(*accent_rgb)}")
    print(f"selection-background = {rgb_to_hex(*space_bg_rgb)}")
    print(f"selection-foreground = {rgb_to_hex(*fg_rgb)}")
    print()
    for i in range(16):
        print(f"palette = {i}={rgb_to_hex(*ansi[i])}")

if __name__ == "__main__":
    main()
