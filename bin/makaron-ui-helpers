#!/bin/bash
# Shared helper functions for Makaron UI scripts

MAKARON_PATH="${MAKARON_PATH:-$HOME/.local/share/makaron}"
UI_MODE_FILE="$HOME/.local/state/makaron/ui-mode"

# Notch detection cache — Swift cold-start (~1s) is too expensive to repeat.
# Invalidate from display_change.sh on monitor hotplug.
NOTCH_CACHE_FILE="/tmp/makaron_has_builtin_notch"

# Constants for desktop layout (kept simple; theme BORDER_WIDTH is unified).
MAKARON_GAPS_WITH_BORDERS=15
MAKARON_GAPS_WITHOUT_BORDERS=8

# --- UI Mode State ---
save_ui_mode() {
    local mode="$1"
    mkdir -p "$(dirname "$UI_MODE_FILE")"
    echo "$mode" > "$UI_MODE_FILE"
}

get_ui_mode() {
    if [ -f "$UI_MODE_FILE" ]; then
        cat "$UI_MODE_FILE"
    else
        echo "full"  # default
    fi
}

reload_current_ui() {
    local mode=$(get_ui_mode)
    case "$mode" in
        full)
            echo "Reloading full UI..."
            start_sketchybar
            apply_desktop_state
            ;;
        minimal)
            echo "Reloading minimal UI..."
            apply_desktop_state
            ;;
        stop)
            echo "UI is stopped, skipping reload."
            ;;
    esac
}

# --- AeroSpace Config ---

# Detect if the built-in display has a notch (safeAreaInsets.top > 0).
# Cached because Swift cold-start (~1s) makes this expensive to repeat.
# Cache is invalidated by display_change.sh on monitor hotplug.
_has_builtin_notch() {
    if [ -f "$NOTCH_CACHE_FILE" ]; then
        [[ "$(cat "$NOTCH_CACHE_FILE" 2>/dev/null)" == "1" ]]
        return
    fi

    local notch
    notch=$(swift -e 'import AppKit; print(NSScreen.screens.contains { $0.safeAreaInsets.top > 0 } ? "1" : "0")' 2>/dev/null)
    [[ -z "$notch" ]] && notch="0"
    echo "$notch" > "$NOTCH_CACHE_FILE" 2>/dev/null || true
    [[ "$notch" == "1" ]]
}

# Invalidate notch cache (call from display_change handler).
invalidate_notch_cache() {
    rm -f "$NOTCH_CACHE_FILE" 2>/dev/null || true
}

_resolve_aerospace_config_path() {
    local config_link="$HOME/.aerospace.toml"
    if [ -L "$config_link" ]; then
        local target="$(readlink "$config_link")"
        [[ "$target" != /* ]] && target="$(dirname "$config_link")/$target"
        echo "$target"
    else
        echo "$config_link"
    fi
}

switch_aerospace_config() {
    local mode="$1"  # "full" or "minimal"

    local config_file
    config_file="$(_resolve_aerospace_config_path)"

    if [ ! -f "$config_file" ]; then
        echo "  ⚠️  AeroSpace config not found: $config_file"
        return 1
    fi

    local has_notch=true
    if ! _has_builtin_notch; then
        has_notch=false
    fi

    source "$HOME/.config/makaron/makaron.conf" 2>/dev/null
    local borders="${BORDERS_ENABLED:-true}"

    case "$mode" in
        full)
            if [[ "$borders" == "true" ]]; then
                if $has_notch; then
                    local outer_top='    outer.top = [{ monitor."Built-in" = 15 }, 45]'
                else
                    local outer_top='    outer.top = 45'
                fi
            else
                if $has_notch; then
                    local outer_top='    outer.top = [{ monitor."Built-in" = 8 }, 42]'
                else
                    local outer_top='    outer.top = 42'
                fi
            fi
            ;;
        minimal)
            local outer_top='    outer.top = 8'
            ;;
        *)
            echo "  ⚠️  Unknown aerospace config mode: $mode"
            return 1
            ;;
    esac

    sed -i '' "s/    outer\.top = .*/$outer_top/" "$config_file"
    echo "  ✓ AeroSpace outer.top set for: $mode mode (notch: $has_notch)"
}

# Set AeroSpace inner/outer gaps (excluding outer.top which depends on SketchyBar/notch).
# Warns if any expected line is missing — usually means user hand-edited the file
# and our sed pattern no longer matches.
_set_aerospace_gaps() {
    local size="$1"  # gap size in px

    local config_file
    config_file="$(_resolve_aerospace_config_path)"
    [ ! -f "$config_file" ] && return 1

    local missing=()
    for key in 'inner.horizontal' 'inner.vertical' 'outer.left' 'outer.bottom' 'outer.right'; do
        local pattern="    ${key//./\\.} ="
        grep -qE "^${pattern}" "$config_file" || missing+=("$key")
    done

    sed -i '' \
        -e "s/    inner\.horizontal = .*/    inner.horizontal = $size/" \
        -e "s/    inner\.vertical =.*/    inner.vertical =   $size/" \
        -e "s/    outer\.left =.*/    outer.left =       $size/" \
        -e "s/    outer\.bottom =.*/    outer.bottom =     $size/" \
        -e "s/    outer\.right =.*/    outer.right =      $size/" \
        "$config_file"

    echo "  ✓ AeroSpace gaps set to ${size}px"
    if [ ${#missing[@]} -gt 0 ]; then
        echo "  ⚠️  Could not set: ${missing[*]} (hand-edited config?)"
    fi
}

# ============================================================================
# apply_desktop_state — single source of truth for layout (gaps + borders + top).
#
# Scope: layout only. Does NOT start/stop AeroSpace, SketchyBar, or apply macOS
# settings. Callers (makaron-ui-full / makaron-ui-minimal) handle bootstrap.
#
# Inputs read: ui-mode state file, BORDERS_ENABLED from makaron.conf,
#              current-theme/borders.colors (via start_borders).
# Outputs:     ~/.aerospace.toml (inner/outer gaps + outer.top),
#              borders process state (start/stop matching ui-mode+config).
# ============================================================================
apply_desktop_state() {
    local ui_mode
    ui_mode=$(get_ui_mode)

    if [ "$ui_mode" = "stop" ]; then
        # In stop mode the user explicitly wants nothing running. Don't touch
        # the toml or borders. Warn if called from makaron-borders so the
        # user isn't surprised that "borders on" did nothing visible.
        if [ -n "${MAKARON_APPLY_VERBOSE:-}" ]; then
            echo "  UI mode is 'stop' — desktop state not applied"
        fi
        return 0
    fi

    source "$HOME/.config/makaron/makaron.conf" 2>/dev/null
    local borders="${BORDERS_ENABLED:-true}"

    local gap_size=$MAKARON_GAPS_WITH_BORDERS
    [ "$borders" != "true" ] && gap_size=$MAKARON_GAPS_WITHOUT_BORDERS

    _set_aerospace_gaps "$gap_size"
    switch_aerospace_config "$ui_mode"

    if command -v aerospace &> /dev/null && pgrep -f "AeroSpace" > /dev/null; then
        aerospace reload-config 2>/dev/null || true
    fi

    if [ "$ui_mode" = "full" ] && [ "$borders" = "true" ]; then
        start_borders
    else
        stop_borders
    fi
}

# ============================================================================
# verify_desktop_state — compare ~/.aerospace.toml + borders process to the
# state that apply_desktop_state would produce. Used by makaron-debug.
# Echoes findings. Returns 0 if synced, 1 if drift detected.
# ============================================================================
verify_desktop_state() {
    local ui_mode
    ui_mode=$(get_ui_mode)
    source "$HOME/.config/makaron/makaron.conf" 2>/dev/null
    local borders="${BORDERS_ENABLED:-true}"

    local expected_gap=$MAKARON_GAPS_WITH_BORDERS
    [ "$borders" != "true" ] && expected_gap=$MAKARON_GAPS_WITHOUT_BORDERS

    local config_file
    config_file="$(_resolve_aerospace_config_path)"

    if [ ! -f "$config_file" ]; then
        echo "  ❌ aerospace config not found: $config_file"
        return 1
    fi

    local drift=0

    local actual_inner_h
    actual_inner_h=$(grep -E '^    inner\.horizontal' "$config_file" | awk '{print $3}')
    if [ "$actual_inner_h" != "$expected_gap" ]; then
        echo "  ⚠️  inner.horizontal=$actual_inner_h, expected $expected_gap"
        drift=1
    fi

    local actual_right
    actual_right=$(grep -E '^    outer\.right' "$config_file" | awk '{print $3}')
    if [ "$actual_right" != "$expected_gap" ]; then
        echo "  ⚠️  outer.right=$actual_right, expected $expected_gap"
        drift=1
    fi

    # outer.top is mode-dependent — full vs minimal produce different shapes,
    # so just sanity-check that minimal has the small value.
    if [ "$ui_mode" = "minimal" ]; then
        if ! grep -qE '^    outer\.top = 8$' "$config_file"; then
            echo "  ⚠️  outer.top doesn't match minimal mode (expected: 8)"
            drift=1
        fi
    fi

    # Borders process state
    local borders_running="false"
    pgrep -x "borders" > /dev/null 2>&1 && borders_running="true"
    local expected_borders="false"
    [ "$ui_mode" = "full" ] && [ "$borders" = "true" ] && expected_borders="true"
    if [ "$borders_running" != "$expected_borders" ]; then
        echo "  ⚠️  borders running=$borders_running, expected $expected_borders (ui-mode=$ui_mode, BORDERS_ENABLED=$borders)"
        drift=1
    fi

    if [ $drift -eq 0 ]; then
        echo "  ✓ Desktop layout state is in sync (ui-mode=$ui_mode, borders=$borders, gap=${expected_gap}px)"
    fi
    return $drift
}

# --- AeroSpace ---
start_aerospace() {
    if command -v aerospace &> /dev/null; then
        if ! pgrep -f "AeroSpace" > /dev/null; then
            echo "  Starting AeroSpace..."
            open -a AeroSpace
            sleep 2
        fi
        echo "  Enabling AeroSpace..."
        aerospace enable on
        aerospace reload-config
        echo "  ✓ AeroSpace enabled and config reloaded"
    else
        echo "  ⚠️  AeroSpace not installed"
    fi
}

stop_aerospace() {
    if command -v aerospace &> /dev/null; then
        if pgrep -f "AeroSpace" > /dev/null; then
            echo "  Disabling AeroSpace..."
            aerospace enable off
            echo "  ✓ AeroSpace disabled"
        else
            echo "  ⚠️  AeroSpace not running"
        fi
    else
        echo "  ⚠️  AeroSpace not installed"
    fi
}

# --- SketchyBar ---
start_sketchybar() {
    if command -v sketchybar &> /dev/null; then
        if ! pgrep -f "sketchybar" > /dev/null; then
            echo "  Starting SketchyBar..."
            brew services start sketchybar
            sleep 2
        fi
        echo "  Reloading SketchyBar config..."
        sketchybar --reload
        echo "  ✓ SketchyBar started and config reloaded"
    else
        echo "  ⚠️  SketchyBar not installed"
    fi
}

stop_sketchybar() {
    if command -v sketchybar &> /dev/null; then
        if brew services list | grep -q "sketchybar.*started"; then
            echo "  Stopping SketchyBar..."
            brew services stop sketchybar 2>/dev/null
            echo "  ✓ SketchyBar stopped"
        else
            echo "  ⚠️  SketchyBar not running"
        fi
    else
        echo "  ⚠️  SketchyBar not installed"
    fi
}

# --- Borders ---
start_borders() {
    source "$HOME/.config/makaron/makaron.conf" 2>/dev/null
    if [[ "${BORDERS_ENABLED:-true}" != "true" ]]; then
        echo "  Borders disabled (makaron.conf)"
        return 0
    fi
    if command -v borders &> /dev/null; then
        local THEME_DIR="$MAKARON_PATH/current-theme"
        if [ -f "$THEME_DIR/borders.colors" ]; then
            source "$THEME_DIR/borders.colors"
        else
            export ACTIVE_BORDER_COLOR=0xff7aa2f7
            export INACTIVE_BORDER_COLOR=0xff292e42
            export BORDER_WIDTH=2.0
        fi
        echo "  Starting Borders with theme colors..."
        brew services stop borders 2>/dev/null || true
        sleep 0.5
        borders active_color=$ACTIVE_BORDER_COLOR inactive_color=$INACTIVE_BORDER_COLOR width=$BORDER_WIDTH &
        echo "  ✓ Borders started with theme colors"
    else
        echo "  ⚠️  Borders not installed"
    fi
}

stop_borders() {
    if command -v borders &> /dev/null; then
        if pgrep -x "borders" > /dev/null; then
            echo "  Stopping Borders..."
            killall borders 2>/dev/null || true
            brew services stop borders 2>/dev/null || true
            sleep 0.5
            if pgrep -x "borders" > /dev/null; then
                echo "  ⚠️  Borders still running, forcing..."
                killall -9 borders 2>/dev/null || true
                sleep 0.5
            fi
            echo "  ✓ Borders stopped"
        else
            echo "  ⚠️  Borders not running"
        fi
    else
        echo "  ⚠️  Borders not installed"
    fi
}

# --- macOS Settings ---

# Toggle menu bar autohide via AppleScript UI click (toggle trick).
# macOS ignores defaults write / CFPreferences — must click the dropdown in System Settings.
_set_menubar_autohide() {
    local target="$1"  # "Always", "In Full Screen Only", or "Never"
    local opposite

    case "$target" in
        "Always"|"In Full Screen Only")
            opposite="Never"
            ;;
        "Never")
            opposite="Always"
            ;;
        *)
            echo "  ⚠️  Unsupported menu bar autohide target: $target"
            return 1
            ;;
    esac

    if ! osascript <<EOF
set targetValue to "$target"
set oppositeValue to "$opposite"
set validValues to {"Always", "On Desktop Only", "In Full Screen Only", "Never"}

on waitForWindow(proc)
    repeat 20 times
        if exists window 1 of proc then return
        delay 0.3
    end repeat
    error "Timed out waiting for System Settings window"
end waitForWindow

on findMenuBarPopup(proc, validValues)
    tell application "System Events"
        tell proc
            repeat 20 times
                set allElements to entire contents of window 1
                repeat with currentElement in allElements
                    try
                        if role of currentElement is "AXPopUpButton" then
                            set currentValue to value of currentElement as text
                            if validValues contains currentValue then return currentElement
                        end if
                    end try
                end repeat
                delay 0.3
            end repeat
        end tell
    end tell
    error "Could not find menu bar autohide popup"
end findMenuBarPopup

on clickMenuItem(menuPopup, menuValue)
    tell application "System Events"
        click menuPopup
        delay 0.8
        click menu item menuValue of menu 1 of menuPopup
    end tell
end clickMenuItem

tell application "System Settings" to quit
delay 1
open location "x-apple.systempreferences:com.apple.ControlCenter-Settings.extension?MenuBar"
delay 2
tell application "System Settings" to activate
delay 1

tell application "System Events"
    tell process "System Settings"
        set frontmost to true
        my waitForWindow(it)
        set menuPopup to my findMenuBarPopup(it, validValues)
        my clickMenuItem(menuPopup, oppositeValue)
        delay 1.5
        set menuPopup to my findMenuBarPopup(it, validValues)
        my clickMenuItem(menuPopup, targetValue)
        delay 1
    end tell
end tell

tell application "System Settings" to quit
EOF
    then
        echo "  ⚠️  Failed to set menu bar autohide to $target"
        echo "     Enable it manually in System Settings > Control Center > Menu Bar"
        return 1
    fi
}

apply_macos_full_settings() {
    echo "  Hiding macOS Dock..."
    defaults write com.apple.dock autohide -bool true
    echo "  ✓ Dock hidden (autohide enabled)"

    echo "  Enabling window grouping by application..."
    defaults write com.apple.dock expose-group-apps -bool true
    killall Dock
    echo "  ✓ Window grouping enabled (required for AeroSpace)"

    echo "  Disabling Three Finger Drag (enabling Mission Control gesture)..."
    defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadThreeFingerDrag -bool false 2>/dev/null
    defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerDrag -bool false 2>/dev/null
    echo "  ✓ Three Finger Swipe Up for Mission Control enabled"

    echo "  Hiding menu bar (auto-hide always)..."
    if _set_menubar_autohide "Always"; then
        echo "  ✓ Menu bar set to auto-hide (Always)"
    else
        echo "  ⚠️  Menu bar autohide was not applied"
    fi
}

apply_macos_minimal_settings() {
    echo "  Showing macOS Dock..."
    defaults write com.apple.dock autohide -bool false
    echo "  ✓ Dock visible (always shown)"

    echo "  Enabling window grouping by application..."
    defaults write com.apple.dock expose-group-apps -bool true
    killall Dock
    echo "  ✓ Window grouping enabled (required for AeroSpace)"

    echo "  Disabling Three Finger Drag (enabling Mission Control gesture)..."
    defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadThreeFingerDrag -bool false 2>/dev/null
    defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerDrag -bool false 2>/dev/null
    echo "  ✓ Three Finger Swipe Up for Mission Control enabled"

    echo "  Showing menu bar on desktop (auto-hide in fullscreen)..."
    if _set_menubar_autohide "In Full Screen Only"; then
        echo "  ✓ Menu bar visible on desktop (In Full Screen Only)"
    else
        echo "  ⚠️  Menu bar visibility was not applied"
    fi
}

restore_macos_defaults() {
    echo "  Showing macOS Dock..."
    defaults write com.apple.dock autohide -bool false
    echo "  ✓ Dock visible"

    echo "  Restoring default window grouping..."
    defaults write com.apple.dock expose-group-apps -bool false
    killall Dock
    echo "  ✓ Window grouping restored to default"

    echo "  Enabling Three Finger Drag..."
    defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadThreeFingerDrag -bool true 2>/dev/null
    defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerDrag -bool true 2>/dev/null
    echo "  ✓ Three Finger Drag enabled"

    echo "  Showing menu bar on desktop (auto-hide in fullscreen)..."
    if _set_menubar_autohide "In Full Screen Only"; then
        echo "  ✓ Menu bar visible on desktop (In Full Screen Only)"
    else
        echo "  ⚠️  Menu bar visibility was not applied"
    fi
}

