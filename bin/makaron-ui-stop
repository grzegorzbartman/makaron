#!/bin/bash
# Stop AeroSpace and SketchyBar

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/makaron-ui-helpers"

echo "🛑 Stopping Makaron UI components..."
echo ""

stop_aerospace
stop_sketchybar
restore_macos_defaults
save_ui_mode "stop"

echo ""
echo "✅ UI components stopped. Use 'makaron-ui-full' to re-enable."
