#!/bin/bash
# Start full Makaron UI: AeroSpace + SketchyBar

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/makaron-ui-helpers"

echo "🚀 Starting Makaron UI (full mode)..."
echo ""

stop_sketchybar

start_aerospace
start_sketchybar
apply_macos_full_settings
save_ui_mode "full"

# Layout derived from ui-mode (single source of truth).
apply_desktop_state

echo ""
echo "✅ Full UI started. Use 'makaron-ui-stop' to disable or 'makaron-ui-minimal' for minimal mode."
