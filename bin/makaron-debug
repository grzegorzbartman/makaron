echo ""

# .DS_Store Settings
echo "📁 .DS_STORE SETTINGS"
echo "────────────────────────────────────────────────────────────────"
DS_NETWORK=$(defaults read com.apple.desktopservices DSDontWriteNetworkStores 2>/dev/null || echo "not set")
echo "  Don't Write .DS_Store on Network Volumes:"
echo "    Value: $DS_NETWORK"
echo "    Expected: 1"
echo ""

DS_USB=$(defaults read com.apple.desktopservices DSDontWriteUSBStores 2>/dev/null || echo "not set")
echo "  Don't Write .DS_Store on USB Volumes:"
echo "    Value: $DS_USB"
echo "    Expected: 1"
echo ""

# Library Folder
echo "📚 LIBRARY FOLDER"
echo "────────────────────────────────────────────────────────────────"
if [ -d "$HOME/Library" ]; then
    LIBRARY_HIDDEN=$(ls -ldO "$HOME/Library" | grep -q "hidden" && echo "hidden" || echo "visible")
    echo "  Library Folder Visibility:"
    echo "    Value: $LIBRARY_HIDDEN"
    echo "    Expected: visible"
else
    echo "  Library folder not found"
fi
echo ""

# Dock Settings
echo "🎯 DOCK SETTINGS"
echo "────────────────────────────────────────────────────────────────"
DOCK_AUTOHIDE=$(defaults read com.apple.dock autohide 2>/dev/null || echo "not set")
echo "  Dock Autohide:"
echo "    Value: $DOCK_AUTOHIDE"
echo "    Expected: 1"
echo ""

DOCK_AUTOHIDE_DELAY=$(defaults read com.apple.Dock autohide-delay 2>/dev/null || echo "not set")
echo "  Dock Autohide Delay:"
echo "    Value: $DOCK_AUTOHIDE_DELAY"
echo "    Expected: 0 (instant)"
echo ""

DOCK_AUTOHIDE_TIME=$(defaults read com.apple.dock autohide-time-modifier 2>/dev/null || echo "not set")
echo "  Dock Autohide Animation Time:"
echo "    Value: $DOCK_AUTOHIDE_TIME"
echo "    Expected: 0 (instant)"
echo ""

EXPOSE_ANIMATION=$(defaults read com.apple.dock expose-animation-duration 2>/dev/null || echo "not set")
echo "  Mission Control Animation Duration:"
echo "    Value: $EXPOSE_ANIMATION"
echo "    Expected: 0.1"
echo ""

MRU_SPACES=$(defaults read com.apple.dock mru-spaces 2>/dev/null || echo "not set")
echo "  Automatically Rearrange Spaces:"
echo "    Value: $MRU_SPACES"
echo "    Expected: 0 (disabled)"
echo ""

EXPOSE_GROUP_APPS=$(defaults read com.apple.dock expose-group-apps 2>/dev/null || echo "not set")
echo "  Mission Control Group Windows by App:"
echo "    Value: $EXPOSE_GROUP_APPS"
echo "    Expected: 1 (fixes AeroSpace window visibility)"
echo ""

# Dock & Menu Bar Settings
echo "📋 DOCK & MENU BAR SETTINGS"
echo "────────────────────────────────────────────────────────────────"
DOCK_AUTOHIDE_STATUS=$(defaults read com.apple.dock autohide 2>/dev/null || echo "not set")
echo "  Dock Autohide:"
if [ "$DOCK_AUTOHIDE_STATUS" = "1" ]; then
    echo "    Status: ✓ Enabled (Dock is hidden)"
    echo "    Value: $DOCK_AUTOHIDE_STATUS"
else
    echo "    Status: ○ Disabled (Dock is visible)"
    echo "    Value: $DOCK_AUTOHIDE_STATUS"
fi
echo ""

MENUBAR_AUTOHIDE=$(defaults read NSGlobalDomain _HIHideMenuBar 2>/dev/null || echo "not set")
echo "  Menu Bar Autohide:"
if [ "$MENUBAR_AUTOHIDE" = "1" ]; then
    echo "    Status: ✓ Enabled (menu bar is hidden)"
    echo "    Value: $MENUBAR_AUTOHIDE"
    echo "    Note: In macOS Sequoia 15+, use System Settings to change"
else
    echo "    Status: ○ Disabled (menu bar is visible)"
    echo "    Value: $MENUBAR_AUTOHIDE"
    echo "    Note: In macOS Sequoia 15+, use System Settings to change"
fi
echo ""

# Accessibility Settings
echo "♿ ACCESSIBILITY SETTINGS"
echo "────────────────────────────────────────────────────────────────"
REDUCE_TRANSPARENCY=$(defaults read com.apple.universalaccess reduceTransparency 2>/dev/null || echo "not set")
echo "  Reduce Transparency:"
if [ "$REDUCE_TRANSPARENCY" = "1" ]; then
    echo "    Status: ✓ Enabled (transparency disabled - better performance)"
    echo "    Value: $REDUCE_TRANSPARENCY"
else
    echo "    Status: ○ Disabled (transparency enabled - visual effects)"
    echo "    Value: $REDUCE_TRANSPARENCY"
fi
echo ""

# iCloud Settings
echo "☁️  ICLOUD SETTINGS"
echo "────────────────────────────────────────────────────────────────"
ICLOUD_SAVE=$(defaults read NSGlobalDomain NSDocumentSaveNewDocumentsToCloud 2>/dev/null || echo "not set")
echo "  Save New Documents to iCloud by Default:"
echo "    Value: $ICLOUD_SAVE"
echo "    Expected: 0 (save to local disk)"
echo ""

# Apple Intelligence
echo "🤖 APPLE INTELLIGENCE"
echo "────────────────────────────────────────────────────────────────"
APPLE_INTELLIGENCE=$(defaults read com.apple.CloudSubscriptionFeatures.optIn "545129924" 2>/dev/null || echo "not set")
echo "  Apple Intelligence:"
echo "    Value: $APPLE_INTELLIGENCE"
echo "    Expected: 0 (disabled)"
echo ""

# ============================================================================
# SECTION: AeroSpace
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🚀 AEROSPACE"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if command -v aerospace &> /dev/null; then
    echo "  ✓ AeroSpace installed"

    # Check if running
    if pgrep -f "AeroSpace" > /dev/null; then
        echo "  ✓ AeroSpace is running"

        # Check enable status
        AEROSPACE_ENABLED=$(aerospace list-workspaces --monitor all 2>/dev/null && echo "enabled" || echo "disabled")
        if [ "$AEROSPACE_ENABLED" = "enabled" ]; then
            echo "  ✓ AeroSpace window management: ENABLED"
        else
            echo "  ○ AeroSpace window management: DISABLED"
        fi

        # List windows
        echo ""
        echo "  Current Windows:"
        aerospace list-windows --all 2>/dev/null | while read -r line; do
            echo "    • $line"
        done || echo "    (Could not retrieve window list)"

        # List workspaces
        echo ""
        echo "  Current Workspaces:"
        aerospace list-workspaces --monitor all 2>/dev/null | while read -r workspace; do
            FOCUSED=$(aerospace list-workspaces --monitor focused 2>/dev/null | grep "^${workspace}$" && echo "← focused" || echo "")
            echo "    • $workspace $FOCUSED"
        done || echo "    (Could not retrieve workspace list)"
    else
        echo "  ⚠️  AeroSpace is NOT running"
    fi

    # Check config
    if [ -L "$HOME/.aerospace.toml" ]; then
        TARGET=$(readlink "$HOME/.aerospace.toml")
        echo ""
        echo "  Config symlink: ✓"
        echo "    Target: $TARGET"
        if [ "$TARGET" = "$MAKARON_PATH/configs/aerospace/.aerospace.toml" ]; then
            echo "    ✓ Points to correct location"
        else
            echo "    ⚠️  Points to different location"
        fi
    else
        echo ""
        echo "  Config symlink: ❌ Not found or not a symlink"
    fi
else
    echo "  ❌ AeroSpace is NOT installed"
fi
echo ""

# ============================================================================
# SECTION: MakaronBar
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "📊 MAKARONBAR"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

MAKARONBAR_BIN="$MAKARON_PATH/bin/makaron-bar"
if [ -f "$MAKARONBAR_BIN" ]; then
    echo "  ✓ Binary exists: $MAKARONBAR_BIN"
else
    echo "  ❌ Binary not found: $MAKARONBAR_BIN"
fi

MAKARONBAR_PID=$(pgrep -f makaron-bar 2>/dev/null)
if [ -n "$MAKARONBAR_PID" ]; then
    echo "  ✓ MakaronBar is running (PID: $MAKARONBAR_PID)"
else
    echo "  ⚠️  MakaronBar is NOT running"
fi
echo ""

# ============================================================================
# SECTION: Todoist
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "📝 TODOIST"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

TODOIST_CONF="$HOME/.config/makaron/makaron.conf"

if [ -f "$TODOIST_CONF" ]; then
    # shellcheck disable=SC1090
    . "$TODOIST_CONF"
fi

TD_BIN=$(_find_td_bin 2>/dev/null || true)

echo "  Config:"
if [ -n "${TODOIST_CLI:-}" ]; then
    echo "    TODOIST_CLI=$TODOIST_CLI"
else
    echo "    TODOIST_CLI=(not set)"
fi
if [ -n "${TODOIST_API_TOKEN:-}" ]; then
    echo "    TODOIST_API_TOKEN=set (${#TODOIST_API_TOKEN} chars)"
else
    echo "    TODOIST_API_TOKEN=(not set)"
fi
if [ -n "$TD_BIN" ]; then
    echo "    Resolved td path: $TD_BIN"
else
    echo "    Resolved td path: (not found)"
fi
echo ""

echo "  Todoist CLI:"
if [ -n "$TD_BIN" ] && [ -x "$TD_BIN" ]; then
    echo "    ✓ Found CLI at: $TD_BIN"
    TODOIST_CLI_OUTPUT=$("$TD_BIN" today --json --full 2>&1)
    TODOIST_CLI_STATUS=$?
    echo "    td today --json --full exit code: $TODOIST_CLI_STATUS"
    if [ $TODOIST_CLI_STATUS -eq 0 ]; then
        if command -v jq &> /dev/null; then
            TODOIST_CLI_COUNT=$(echo "$TODOIST_CLI_OUTPUT" | jq -r '.results | length' 2>/dev/null)
            TODOIST_CLI_TITLE=$(echo "$TODOIST_CLI_OUTPUT" | jq -r "$_todoist_jq_cli" 2>/dev/null)
            echo "    Tasks returned: ${TODOIST_CLI_COUNT:-unknown}"
            [ -n "$TODOIST_CLI_TITLE" ] && echo "    Next task: $TODOIST_CLI_TITLE" || echo "    Next task: (none)"
        else
            echo "    jq missing - cannot parse CLI JSON"
        fi
    else
        echo "    ⚠️  CLI request failed"
        echo "    Output: $(echo "$TODOIST_CLI_OUTPUT" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-220)"
    fi
else
    echo "    ⚠️  CLI not found by plugin resolver"
fi
echo ""

echo "  Todoist API fallback:"
if [ -n "${TODOIST_API_TOKEN:-}" ]; then
    if command -v curl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
        TODOIST_API_OUTPUT=$(curl -sf -G "https://api.todoist.com/rest/v2/tasks" \
            -H "Authorization: Bearer ${TODOIST_API_TOKEN}" \
            --data-urlencode "filter=today | overdue" 2>&1)
        TODOIST_API_STATUS=$?
        echo "    API request exit code: $TODOIST_API_STATUS"
        if [ $TODOIST_API_STATUS -eq 0 ]; then
            TODOIST_API_COUNT=$(echo "$TODOIST_API_OUTPUT" | jq -r 'length' 2>/dev/null)
            TODOIST_API_TITLE=$(echo "$TODOIST_API_OUTPUT" | jq -r "$_todoist_jq_api" 2>/dev/null)
            echo "    Tasks returned: ${TODOIST_API_COUNT:-unknown}"
            [ -n "$TODOIST_API_TITLE" ] && echo "    Next task: $TODOIST_API_TITLE" || echo "    Next task: (none)"
        else
            echo "    ⚠️  API request failed"
            echo "    Output: $(echo "$TODOIST_API_OUTPUT" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-220)"
        fi
    else
        echo "    ⚠️  curl and/or jq missing"
    fi
else
    echo "    Skipped - TODOIST_API_TOKEN not set"
fi
echo ""

# ============================================================================
# SECTION: Timewarrior Timer
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "⏱️  TIMEWARRIOR TIMER"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

TIMER_CMD="$MAKARON_PATH/bin/makaron-timer"
TIMER_CONF="$HOME/.config/makaron/makaron.conf"
MAKARON_TIMER_ENABLED="true"

if [ -f "$TIMER_CONF" ]; then
    # shellcheck disable=SC1090
    . "$TIMER_CONF"
fi

echo "  Config:"
echo "    MAKARON_TIMER_ENABLED=${MAKARON_TIMER_ENABLED}"
echo "    MAKARON_TIMER_DEFAULT_TAG=${MAKARON_TIMER_DEFAULT_TAG:-default}"
echo "    MAKARON_TIMER_RECENT_COUNT=${MAKARON_TIMER_RECENT_COUNT:-5}"
echo ""

echo "  Files:"
[ -x "$TIMER_CMD" ] && echo "    ✓ Command exists: $TIMER_CMD" || echo "    ❌ Command missing or not executable: $TIMER_CMD"
echo ""

echo "  Timewarrior:"
if command -v timew &> /dev/null; then
    echo "    ✓ timew installed"
    TIMER_ACTIVE=$(timew get dom.active 2>/dev/null || echo "0")
    echo "    Active tracking: $TIMER_ACTIVE"
else
    echo "    ⚠️  timew not installed"
fi
echo ""

echo "  makaron-timer status:"
if [ -x "$TIMER_CMD" ]; then
    TIMER_STATUS_OUTPUT=$("$TIMER_CMD" status 2>&1)
    TIMER_STATUS_EXIT=$?
    echo "    exit code: $TIMER_STATUS_EXIT"
    if [ $TIMER_STATUS_EXIT -eq 0 ]; then
        echo "    output: $(echo "$TIMER_STATUS_OUTPUT" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-220)"
    else
        echo "    ⚠️  command failed"
        echo "    output: $(echo "$TIMER_STATUS_OUTPUT" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-220)"
    fi
fi
echo ""

echo ""

# ============================================================================
# SECTION: Ghostty Terminal
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "👻 GHOSTTY TERMINAL"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

GHOSTTY_CONFIG="$MAKARON_PATH/configs/ghostty/config"

if [ -f "$GHOSTTY_CONFIG" ]; then
    echo "  ✓ Config file exists"
    echo "    Path: $GHOSTTY_CONFIG"

    if [ -w "$GHOSTTY_CONFIG" ]; then
        echo "    ✓ File is writable"
    else
        echo "    ❌ File is NOT writable!"
    fi

else
    echo "  ❌ Config file does not exist!"
fi

# Check symlink
SYMLINK_PATH="$HOME/.config/ghostty"
if [ -L "$SYMLINK_PATH" ]; then
    TARGET=$(readlink "$SYMLINK_PATH")
    echo "  Config symlink: ✓"
    echo "    Target: $TARGET"
    if [ "$TARGET" = "$MAKARON_PATH/configs/ghostty" ]; then
        echo "    ✓ Points to correct location"
    else
        echo "    ⚠️  Points to different location"
    fi
else
    echo "  Config symlink: ❌ Not found or not a symlink"
fi

echo ""

# ============================================================================
# SECTION: Summary
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "📋 SUMMARY"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Count issues
ERRORS=0
WARNINGS=0

# Check critical components
[ ! -d "$MAKARON_PATH" ] && ((ERRORS++))
! command -v aerospace &> /dev/null && ((WARNINGS++))
[ ! -f "$MAKARON_PATH/bin/makaron-bar" ] && ((WARNINGS++))
! pgrep -f makaron-bar > /dev/null 2>&1 && ((WARNINGS++))

if [ $ERRORS -eq 0 ] && [ $WARNINGS -eq 0 ]; then
    echo "  ✅ All systems operational"
elif [ $ERRORS -eq 0 ]; then
    echo "  ⚠️  $WARNINGS warning(s) found"
else
    echo "  ❌ $ERRORS error(s) and $WARNINGS warning(s) found"
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
