AUTO_QUOTE=$(defaults read NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled 2>/dev/null || echo "not set")
echo "  Automatic Quote Substitution:"
echo "    Value: $AUTO_QUOTE"
