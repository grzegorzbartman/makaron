echo "📊 SKETCHYBAR"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if command -v sketchybar &> /dev/null; then
    echo "  ✓ SketchyBar installed"

    # Check if running
    if pgrep -f "sketchybar" > /dev/null; then
        echo "  ✓ SketchyBar is running"
    else
        echo "  ⚠️  SketchyBar is NOT running"
    fi

    # Check brew service
    if brew services list | grep -q "sketchybar.*started"; then
        echo "  ✓ Brew service: started"
    else
        echo "  ○ Brew service: stopped"
    fi

    # Check config
    if [ -L "$HOME/.config/sketchybar" ]; then
        TARGET=$(readlink "$HOME/.config/sketchybar")
        echo "  Config symlink: ✓"
        echo "    Target: $TARGET"
        if [ "$TARGET" = "$MAKARON_PATH/configs/sketchybar" ]; then
            echo "    ✓ Points to correct location"
        else
            echo "    ⚠️  Points to different location"
        fi
    else
        echo "  Config symlink: ❌ Not found or not a symlink"
    fi
else
    echo "  ❌ SketchyBar is NOT installed"
fi
echo ""

# ============================================================================
# SECTION: Todoist (SketchyBar)
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "📝 TODOIST (SKETCHYBAR)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

TODOIST_PLUGIN="$MAKARON_PATH/configs/sketchybar/plugins/todoist.sh"
TODOIST_SKETCHYBARRC="$MAKARON_PATH/configs/sketchybar/sketchybarrc"
TODOIST_CONF="$HOME/.config/makaron/makaron.conf"
SKETCHYBAR_TODOIST_ENABLED="true"

if [ -f "$TODOIST_CONF" ]; then
    # shellcheck disable=SC1090
    . "$TODOIST_CONF"
fi

TD_BIN=$(_find_td_bin 2>/dev/null || true)

echo "  Config:"
echo "    SKETCHYBAR_TODOIST_ENABLED=${SKETCHYBAR_TODOIST_ENABLED}"
if [ -n "${TODOIST_CLI:-}" ]; then
    echo "    TODOIST_CLI=$TODOIST_CLI"
else
    echo "    TODOIST_CLI=(not set)"
fi
if [ -n "${TODOIST_API_TOKEN:-}" ]; then
    echo "    TODOIST_API_TOKEN=set (${#TODOIST_API_TOKEN} chars)"
else
    echo "    TODOIST_API_TOKEN=(not set)"
fi
if [ -n "$TD_BIN" ]; then
    echo "    Resolved plugin td path: $TD_BIN"
else
    echo "    Resolved plugin td path: (not found)"
fi
echo ""

echo "  Plugin files:"
if [ -f "$TODOIST_PLUGIN" ]; then
    echo "    ✓ Plugin exists: $TODOIST_PLUGIN"
else
    echo "    ❌ Plugin missing: $TODOIST_PLUGIN"
fi

if [ -f "$TODOIST_SKETCHYBARRC" ]; then
    if grep -q 'script="\$PLUGIN_DIR/todoist\.sh"' "$TODOIST_SKETCHYBARRC"; then
        echo "    ✓ sketchybarrc references todoist.sh"
    else
        echo "    ⚠️  sketchybarrc does not reference todoist.sh"
    fi

    if grep -q 'sketchybar --add item todoist ' "$TODOIST_SKETCHYBARRC"; then
        echo "    ✓ sketchybarrc adds todoist item"
    else
        echo "    ⚠️  sketchybarrc does not add todoist item"
    fi
else
    echo "    ❌ sketchybarrc missing: $TODOIST_SKETCHYBARRC"
fi
echo ""

echo "  SketchyBar item state:"
if command -v sketchybar &> /dev/null; then
    TODOIST_QUERY=$(sketchybar --query todoist 2>/dev/null)
    if [ $? -eq 0 ] && [ -n "$TODOIST_QUERY" ]; then
        echo "    ✓ todoist item is registered in SketchyBar"
        if command -v jq &> /dev/null; then
            TODOIST_DRAWING=$(echo "$TODOIST_QUERY" | jq -r '.geometry.drawing // "unknown"' 2>/dev/null)
            TODOIST_LABEL=$(echo "$TODOIST_QUERY" | jq -r '.label.value // empty' 2>/dev/null)
            TODOIST_SCRIPT=$(echo "$TODOIST_QUERY" | jq -r '.scripting.script // empty' 2>/dev/null)
            echo "    drawing=$TODOIST_DRAWING"
            [ -n "$TODOIST_LABEL" ] && echo "    label=$TODOIST_LABEL" || echo "    label=(empty)"
            [ -n "$TODOIST_SCRIPT" ] && echo "    script=$TODOIST_SCRIPT"
        fi
    else
        echo "    ⚠️  todoist item is NOT registered in SketchyBar"
        if [ "$SKETCHYBAR_TODOIST_ENABLED" = "false" ]; then
            echo "    Note: item is disabled by SKETCHYBAR_TODOIST_ENABLED=false"
        fi
    fi
else
    echo "    SketchyBar command unavailable"
fi
echo ""

echo "  Todoist CLI:"
if [ -n "$TD_BIN" ] && [ -x "$TD_BIN" ]; then
    echo "    ✓ Found CLI at: $TD_BIN"
    TODOIST_CLI_OUTPUT=$("$TD_BIN" today --json --full 2>&1)
    TODOIST_CLI_STATUS=$?
    echo "    td today --json --full exit code: $TODOIST_CLI_STATUS"
    if [ $TODOIST_CLI_STATUS -eq 0 ]; then
        if command -v jq &> /dev/null; then
            TODOIST_CLI_COUNT=$(echo "$TODOIST_CLI_OUTPUT" | jq -r '.results | length' 2>/dev/null)
            TODOIST_CLI_TITLE=$(echo "$TODOIST_CLI_OUTPUT" | jq -r "$_todoist_jq_cli" 2>/dev/null)
            echo "    Tasks returned: ${TODOIST_CLI_COUNT:-unknown}"
            [ -n "$TODOIST_CLI_TITLE" ] && echo "    Next task: $TODOIST_CLI_TITLE" || echo "    Next task: (none)"
        else
            echo "    jq missing - cannot parse CLI JSON"
        fi
    else
        echo "    ⚠️  CLI request failed"
        echo "    Output: $(echo "$TODOIST_CLI_OUTPUT" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-220)"
    fi
else
    echo "    ⚠️  CLI not found by plugin resolver"
fi
echo ""

echo "  Todoist API fallback:"
if [ -n "${TODOIST_API_TOKEN:-}" ]; then
    if command -v curl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
        TODOIST_API_OUTPUT=$(curl -sf -G "https://api.todoist.com/rest/v2/tasks" \
            -H "Authorization: Bearer ${TODOIST_API_TOKEN}" \
            --data-urlencode "filter=today | overdue" 2>&1)
        TODOIST_API_STATUS=$?
        echo "    API request exit code: $TODOIST_API_STATUS"
        if [ $TODOIST_API_STATUS -eq 0 ]; then
            TODOIST_API_COUNT=$(echo "$TODOIST_API_OUTPUT" | jq -r 'length' 2>/dev/null)
            TODOIST_API_TITLE=$(echo "$TODOIST_API_OUTPUT" | jq -r "$_todoist_jq_api" 2>/dev/null)
            echo "    Tasks returned: ${TODOIST_API_COUNT:-unknown}"
            [ -n "$TODOIST_API_TITLE" ] && echo "    Next task: $TODOIST_API_TITLE" || echo "    Next task: (none)"
        else
            echo "    ⚠️  API request failed"
            echo "    Output: $(echo "$TODOIST_API_OUTPUT" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-220)"
        fi
    else
        echo "    ⚠️  curl and/or jq missing"
    fi
else
    echo "    Skipped - TODOIST_API_TOKEN not set"
fi
echo ""

# ============================================================================
# SECTION: Timewarrior Timer (SketchyBar)
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "⏱️  TIMEWARRIOR TIMER"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

TIMER_PLUGIN="$MAKARON_PATH/configs/sketchybar/plugins/timer.sh"
TIMER_CMD="$MAKARON_PATH/bin/makaron-timer"
TIMER_CONF="$HOME/.config/makaron/makaron.conf"
SKETCHYBAR_TIMER_ENABLED="true"

if [ -f "$TIMER_CONF" ]; then
    # shellcheck disable=SC1090
    . "$TIMER_CONF"
fi

echo "  Config:"
echo "    SKETCHYBAR_TIMER_ENABLED=${SKETCHYBAR_TIMER_ENABLED}"
echo "    SKETCHYBAR_TIMER_DEFAULT_TAG=${SKETCHYBAR_TIMER_DEFAULT_TAG:-default}"
echo "    SKETCHYBAR_TIMER_RECENT_COUNT=${SKETCHYBAR_TIMER_RECENT_COUNT:-5}"
echo ""

echo "  Files:"
[ -f "$TIMER_PLUGIN" ] && echo "    ✓ Plugin exists: $TIMER_PLUGIN" || echo "    ❌ Plugin missing: $TIMER_PLUGIN"
[ -x "$TIMER_CMD" ] && echo "    ✓ Command exists: $TIMER_CMD" || echo "    ❌ Command missing or not executable: $TIMER_CMD"
echo ""

echo "  Timewarrior:"
if command -v timew &> /dev/null; then
    echo "    ✓ timew installed"
    TIMER_ACTIVE=$(timew get dom.active 2>/dev/null || echo "0")
    echo "    Active tracking: $TIMER_ACTIVE"
else
    echo "    ⚠️  timew not installed"
fi
echo ""

echo "  makaron-timer status:"
if [ -x "$TIMER_CMD" ]; then
    TIMER_STATUS_OUTPUT=$("$TIMER_CMD" status 2>&1)
    TIMER_STATUS_EXIT=$?
    echo "    exit code: $TIMER_STATUS_EXIT"
    if [ $TIMER_STATUS_EXIT -eq 0 ]; then
        echo "    output: $(echo "$TIMER_STATUS_OUTPUT" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-220)"
    else
        echo "    ⚠️  command failed"
        echo "    output: $(echo "$TIMER_STATUS_OUTPUT" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-220)"
    fi
fi
echo ""

echo "  SketchyBar item state:"
if command -v sketchybar &> /dev/null; then
    TIMER_QUERY=$(sketchybar --query timer 2>/dev/null)
    if [ $? -eq 0 ] && [ -n "$TIMER_QUERY" ]; then
        echo "    ✓ timer item is registered in SketchyBar"
        if command -v jq &> /dev/null; then
            TIMER_DRAWING=$(echo "$TIMER_QUERY" | jq -r '.geometry.drawing // "unknown"' 2>/dev/null)
            TIMER_LABEL=$(echo "$TIMER_QUERY" | jq -r '.label.value // empty' 2>/dev/null)
            TIMER_SCRIPT=$(echo "$TIMER_QUERY" | jq -r '.scripting.script // empty' 2>/dev/null)
            echo "    drawing=$TIMER_DRAWING"
            [ -n "$TIMER_LABEL" ] && echo "    label=$TIMER_LABEL" || echo "    label=(empty)"
            [ -n "$TIMER_SCRIPT" ] && echo "    script=$TIMER_SCRIPT"
        fi
    else
        echo "    ⚠️  timer item is NOT registered in SketchyBar"
        if [ "$SKETCHYBAR_TIMER_ENABLED" = "false" ]; then
            echo "    Note: item is disabled by SKETCHYBAR_TIMER_ENABLED=false"
        fi
    fi
else
    echo "    SketchyBar command unavailable"
fi
echo ""

# ============================================================================
# SECTION: Borders
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🔲 BORDERS"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if command -v borders &> /dev/null; then
    echo "  ✓ Borders installed"

    # Check if running
    if pgrep -f "borders" > /dev/null; then
        echo "  ✓ Borders is running"
    else
        echo "  ⚠️  Borders is NOT running"
    fi

    # Check brew service
    if brew services list | grep -q "borders.*started"; then
        echo "  ✓ Brew service: started"
    else
        echo "  ○ Brew service: stopped"
    fi
else
    echo "  ❌ Borders is NOT installed"
fi
echo ""

# ============================================================================
# SECTION: Ghostty Terminal
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "👻 GHOSTTY TERMINAL"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

GHOSTTY_CONFIG="$MAKARON_PATH/configs/ghostty/config"

if [ -f "$GHOSTTY_CONFIG" ]; then
    echo "  ✓ Config file exists"
    echo "    Path: $GHOSTTY_CONFIG"

    if [ -w "$GHOSTTY_CONFIG" ]; then
        echo "    ✓ File is writable"
    else
        echo "    ❌ File is NOT writable!"
    fi

    # Check theme line
    if grep -q "^theme = " "$GHOSTTY_CONFIG"; then
        THEME_LINE=$(grep "^theme = " "$GHOSTTY_CONFIG")
        echo "    Current theme: $THEME_LINE"
    else
        echo "    ⚠️  No theme line found in config"
    fi
else
    echo "  ❌ Config file does not exist!"
fi

# Check symlink
SYMLINK_PATH="$HOME/.config/ghostty"
if [ -L "$SYMLINK_PATH" ]; then
    TARGET=$(readlink "$SYMLINK_PATH")
    echo "  Config symlink: ✓"
    echo "    Target: $TARGET"
    if [ "$TARGET" = "$MAKARON_PATH/configs/ghostty" ]; then
        echo "    ✓ Points to correct location"
    else
        echo "    ⚠️  Points to different location"
    fi
else
    echo "  Config symlink: ❌ Not found or not a symlink"
fi

# Check GHOSTTY_THEME env var
if [ -n "$GHOSTTY_THEME" ]; then
    echo "  GHOSTTY_THEME env: $GHOSTTY_THEME"
else
    echo "  GHOSTTY_THEME env: (not set)"
fi

# Check actual config file content
echo ""
echo "  Ghostty Config File Content:"
echo "  ────────────────────────────────────────────────────────────────"
if [ -f "$HOME/.config/ghostty/config" ]; then
    echo "  Location: $HOME/.config/ghostty/config"
    if grep -q "^theme = " "$HOME/.config/ghostty/config"; then
        THEME_VALUE=$(grep "^theme = " "$HOME/.config/ghostty/config" | head -1)
        echo "  Theme line: $THEME_VALUE"

        # Check for "One Dark" references
        if echo "$THEME_VALUE" | grep -qi "One Dark"; then
            echo "  ❌ ERROR: Config contains 'One Dark' theme (does not exist in Ghostty!)"
        else
            echo "  ✓ No 'One Dark' references found"
        fi
    else
        echo "  ⚠️  No theme line found"
    fi
else
    echo "  ❌ Config file not found at $HOME/.config/ghostty/config"
fi

# Check shell config files for GHOSTTY_THEME
echo ""
echo "  Shell Config Files:"
echo "  ────────────────────────────────────────────────────────────────"
for config_file in "$HOME/.zshrc" "$HOME/.bashrc"; do
    if [ -f "$config_file" ]; then
        echo "  $(basename $config_file):"
        if grep -q "GHOSTTY_THEME" "$config_file"; then
            GHOSTTY_LINE=$(grep "GHOSTTY_THEME" "$config_file" | tail -1)
            echo "    Found: $GHOSTTY_LINE"
            if echo "$GHOSTTY_LINE" | grep -qi "One Dark"; then
                echo "    ❌ ERROR: Contains 'One Dark' theme reference!"
            else
                echo "    ✓ No 'One Dark' references"
            fi
        else
            echo "    No GHOSTTY_THEME variable found"
        fi
    fi
done

# Check migration status
echo ""
echo "  Migration Status (1764134080 - Fix One Dark):"
echo "  ────────────────────────────────────────────────────────────────"
MIGRATION_STATE_DIR="$HOME/.local/state/makaron/migrations"
if [ -f "$MIGRATION_STATE_DIR/1764134080.sh" ]; then
    echo "  ✓ Migration completed"
    echo "    Completed at: $(stat -f "%Sm" "$MIGRATION_STATE_DIR/1764134080.sh" 2>/dev/null || stat -c "%y" "$MIGRATION_STATE_DIR/1764134080.sh" 2>/dev/null)"
elif [ -f "$MIGRATION_STATE_DIR/skipped/1764134080.sh" ]; then
    echo "  ⚠️  Migration was skipped"
else
    echo "  ⚠️  Migration NOT run yet (run: makaron-migrate)"
fi
echo ""

# ============================================================================
# SECTION: Current Theme
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🎨 CURRENT THEME"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

THEME_DIR="$MAKARON_PATH/current-theme"
if [ -L "$THEME_DIR" ]; then
    TARGET=$(readlink "$THEME_DIR")
    THEME_NAME=$(basename "$TARGET")
    echo "  ✓ Current theme: $THEME_NAME"
    echo "    Path: $TARGET"

    # Check mode
    if [ -f "$THEME_DIR/mode" ]; then
        MODE=$(cat "$THEME_DIR/mode")
        echo "    Mode: $MODE"
    fi

    # Check if theme files exist
    echo ""
    echo "  Theme files:"
    [ -f "$THEME_DIR/borders.colors" ] && echo "    ✓ borders.colors" || echo "    ⚠️  borders.colors missing"
    [ -f "$THEME_DIR/sketchybar.colors" ] && echo "    ✓ sketchybar.colors" || echo "    ⚠️  sketchybar.colors missing"
else
    echo "  ⚠️  No theme symlink found"
fi
echo ""

# ============================================================================
# SECTION: Summary
# ============================================================================
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "📋 SUMMARY"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Count issues
ERRORS=0
WARNINGS=0

# Check critical components
[ ! -d "$MAKARON_PATH" ] && ((ERRORS++))
! command -v aerospace &> /dev/null && ((WARNINGS++))
! command -v sketchybar &> /dev/null && ((WARNINGS++))
! command -v borders &> /dev/null && ((WARNINGS++))

if [ $ERRORS -eq 0 ] && [ $WARNINGS -eq 0 ]; then
    echo "  ✅ All systems operational"
elif [ $ERRORS -eq 0 ]; then
    echo "  ⚠️  $WARNINGS warning(s) found"
else
    echo "  ❌ $ERRORS error(s) and $WARNINGS warning(s) found"
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
