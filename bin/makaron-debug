SAVE_EXPANDED=$(defaults read NSGlobalDomain NSNavPanelExpandedStateForSaveMode 2>/dev/null || echo "not set")
echo "  Expanded Save Dialogs:"
echo "    Value: $SAVE_EXPANDED"
