#!/bin/bash

# Universal diagnostic script for Makaron system
# Checks configuration, status, and settings across all components

echo "╔══════════════════════════════════════════════════════════════╗"
echo "║          Makaron System Diagnostic Tool                     ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

# Set MAKARON_PATH
MAKARON_PATH="${MAKARON_PATH:-$HOME/.local/share/makaron}"

_todoist_jq_cli='
  [.results[] | . + {
    _has_time: (if .due.datetime != null then 0 else 1 end),
    _time: (if .due.datetime != null then .due.datetime else "9999-12-31T23:59:59Z" end),
    _prio: (-((.priority // 1)))
  }]
  | sort_by(._has_time, ._prio, ._time, .dayOrder)
  | .[0].content // empty
'

_todoist_jq_api='
  [.[] | . + {
    _has_time: (if .due.datetime != null then 0 else 1 end),
    _time: (if .due.datetime != null then .due.datetime else (.due.date // "9999-12-31") + "T23:59:59Z" end),
    _prio: (-((.priority // 1)))
  }]
  | sort_by(._has_time, ._time, ._prio, .createdAt)
  | .[0].content // empty
'

_find_td_bin() {
    local candidate
    local plugin_path="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

    if [ -n "${TODOIST_CLI:-}" ] && [ -x "$TODOIST_CLI" ]; then
        echo "$TODOIST_CLI"
        return 0
    fi

    candidate=$(PATH="$plugin_path" command -v td 2>/dev/null)
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
        echo "$candidate"
        return 0
    fi

    for candidate in \
        "$HOME/.nvm/versions/node"/*/bin/td \
        "$HOME/.fnm/node-versions"/*/installation/bin/td \
        "$HOME/Library/Application Support/fnm/node-versions"/*/installation/bin/td \
        "$HOME/.volta/bin/td" \
        "$HOME/.npm-global/bin/td"
    do
        if [ -x "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

