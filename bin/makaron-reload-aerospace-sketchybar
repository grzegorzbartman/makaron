#!/bin/bash
# Reload AeroSpace + SketchyBar and re-derive layout state (gaps, outer.top, borders).
# All layout decisions live in apply_desktop_state (single source of truth).

MAKARON_PATH="${MAKARON_PATH:-$HOME/.local/share/makaron}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$SCRIPT_DIR/makaron-ui-helpers"

# Start AeroSpace if not running (apply_desktop_state will trigger reload-config).
if ! pgrep -f "AeroSpace" > /dev/null; then
    echo "AeroSpace not running, starting..."
    open -a AeroSpace
    sleep 2
fi

# Restart SketchyBar so it picks up theme colors / config changes.
brew services restart sketchybar 2>/dev/null || true

# Layout + borders — apply_desktop_state reads current theme via start_borders.
apply_desktop_state
