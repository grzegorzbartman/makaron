#!/bin/bash
# Start minimal Makaron UI: only AeroSpace

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/makaron-ui-helpers"

echo "🚀 Starting Makaron UI (minimal mode)..."
echo ""

stop_sketchybar

start_aerospace
apply_macos_minimal_settings
save_ui_mode "minimal"

# Layout (gaps + outer.top).
apply_desktop_state

echo ""
echo "✅ Minimal UI started (AeroSpace only). Use 'makaron-ui-full' for full mode or 'makaron-ui-stop' to disable."
