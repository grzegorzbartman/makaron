# Makaron configuration file
# ~/.config/makaron/makaron.conf

# Battery low threshold (percentage)
BATTERY_LOW_THRESHOLD=20

# SketchyBar: hide CPU / memory / storage widgets (more room for workspaces)
SKETCHYBAR_COMPACT_MODE=false

# SketchyBar: hide empty AeroSpace workspaces from the bar
# The focused workspace is always drawn, even if it's empty.
SKETCHYBAR_HIDE_EMPTY_WORKSPACES=true

# SketchyBar: Apple Notes — click to create a new note in a new window
SKETCHYBAR_NOTES_ENABLED=false

